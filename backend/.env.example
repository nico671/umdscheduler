# Backend runtime environment template
# Copy this file to backend/.env and fill in values for your environment.

# App mode: development | staging | production | test
APP_ENV=development

# Comma-separated list of allowed origins for CORS (no trailing slash)
CORS_ORIGINS=http://localhost:5173,https://umdscheduler.vercel.app

# Whether CORS should include credentials for cross-origin requests
CORS_ALLOW_CREDENTIALS=true

# Optional: full Postgres DSN for hosted DBs
# Example: postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# SSL mode for hosted Postgres connections when DATABASE_URL is set
DB_SSL_MODE=require

# Connection pool sizing
DB_POOL_MIN=1
DB_POOL_MAX=20

# DB network and keepalive tuning
DB_CONNECT_TIMEOUT=10
DB_KEEPALIVES=1
DB_KEEPALIVES_IDLE=30
DB_KEEPALIVES_INTERVAL=10
DB_KEEPALIVES_COUNT=5

# Rate-limit budgets (fixed window)
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_GLOBAL_PER_IP=400
API_RATE_LIMIT_GLOBAL_BURST=100

# Strict schedule-generation route budget (POST /api/v1/schedules)
API_RATE_LIMIT_SCHEDULES_PER_IP=8
API_RATE_LIMIT_SCHEDULES_BURST=2

# Maximum schedule payload body size in bytes
API_SCHEDULE_MAX_BODY_BYTES=64000
